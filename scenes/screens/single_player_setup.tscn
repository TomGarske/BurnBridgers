[node name="SinglePlayerSetup" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_sp_setup")

[node name="HomeScreenBackground" type="CanvasLayer" parent="."]
script = ExtResource("2_home_screen_background")

[node name="BackdropTint" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2
color = Color(0.04, 0.08, 0.16, 0.35)

[node name="ConfigPanel" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -220.0
offset_top = -280.0
offset_right = 220.0
offset_bottom = 280.0
theme_override_styles/panel = SubResource("StyleBoxFlat_config_panel")

[node name="VBoxContainer" type="VBoxContainer" parent="ConfigPanel"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 10
alignment = 1

[node name="Title" type="Label" parent="ConfigPanel/VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.937255, 0.964706, 1, 1)
theme_override_font_sizes/font_size = 26
text = "SINGLE PLAYER"
horizontal_alignment = 1

[node name="Tagline" type="Label" parent="ConfigPanel/VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.631373, 0.733333, 0.866667, 0.95)
theme_override_font_sizes/font_size = 12
text = "Configure your solo operation"
horizontal_alignment = 1

[node name="Sep1" type="HSeparator" parent="ConfigPanel/VBoxContainer"]
layout_mode = 2

[node name="GameTypeLabel" type="Label" parent="ConfigPanel/VBoxContainer"]
layout_mode = 2
